node_modules/ # Excluye todas las dependencias de Node instaladas localmente
.env # Excluye el archivo de credenciales para evitar fugas de seguridad
test-results/ # Excluye trazas y capturas de pantalla de ejecuciones previas
playwright-report/ # Excluye el reporte visual generado tras correr los tests
blob-report/ # Excluye reportes temporales de ejecuciones en paralelo
playwright/.cache/ # Excluye los binarios descargados de los navegadores
dist/ # Excluye la carpeta de código compilado de TypeScript
.DS_Store # Excluye archivos ocultos de gestión de sistema de macOS
npm-debug.log* # Excluye registros de depuración de errores de npm
yarn-debug.log* # Excluye registros de depuración de errores de yarn
yarn-error.log* # Excluye registros de errores fatales de yarn
*.zip # Excluye cualquier archivo comprimido (como las trazas de Playwright)
*.log # Excluye archivos de registro de texto plano generados por el sistema
package-lock.json # Opcional: algunos prefieren no subirlo para flexibilizar versiones
.vscode/ # Excluye configuraciones locales del editor Visual Studio Code